# Discord bot credentials and runtime scope.
# Copy this file to .env for local development and fill in real values there.
# Do not commit real tokens, secrets, or Google service account JSON files.

DISCORD_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_GUILD_ID=
DISCORD_ALLOWED_CHANNEL_IDS=

# Google Sheets integration for the MVP storage path.
# Use a local filesystem path to a service account JSON file.
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_SPREADSHEET_ID=
